// 1000 indv, 9999 sites
initialize() {
    defineConstant("FLAG_FILE", "flag.txt");
    initializeMutationRate(1e-07);
    initializeMutationType("m1", 0.5, "f", 0.0);
    initializeGenomicElementType("g1", m1, 1.0);
    initializeGenomicElement(g1, 0, 9999);
    initializeRecombinationRate(1e-08);
}

1 early() {
    sim.addSubpop("p1", 1000);
    mutRate = 1e-07;
}

90:100 late() {
    if (community.tick % 10 == 0) {
        g = p1.sampleIndividuals(100).haplosomes;
        g.outputHaplosomesToMS("state.txt", append=T);
    }
}

// Population size oscillates like a sine wave
101:500 early() {
    if (community.tick % 10 == 0) {
        // Sine wave population size between 1000 and 19000
        t = community.tick - 101;
        period = 20;
        newSize = asInteger(1000 + 900 * sin(2 * PI * t / period));
        if (newSize < 100) newSize = 100;
        p1.setSubpopulationSize(newSize);

        // Agent-controlled mutation rate
        while (fileExists(FLAG_FILE) == F) {}
        mutRateStr = readFile(FLAG_FILE);
        while (size(mutRateStr) == 0) {
            mutRateStr = readFile(FLAG_FILE);
        }
        mutRate = asFloat(mutRateStr);
        sim.chromosome.setMutationRate(mutRate);
    }
}

101:500 late() {
    if (community.tick % 10 == 0) {
        g = p1.sampleIndividuals(100).haplosomes;
        g.outputHaplosomesToMS("state.txt", append=T);
        deleteFile(FLAG_FILE);
    }
}

501 late() {
    while (fileExists(FLAG_FILE) == F) {}
    writeFile("generation_complete.txt", "1");
}
